# ID del Google Spreadsheet (lo encuentras en la URL del sheet)
GOOGLE_SHEETS_ID=

# ID del calendario principal (generalmente es el email de la cuenta Google)
GOOGLE_CALENDAR_ID=

# String aleatorio para seguridad de sesiones Flask
FLASK_SECRET_KEY=cambia-esto-por-un-string-aleatorio-largo

# --- OAuth2 (Google Cloud Console → Credenciales → ID de cliente OAuth 2.0) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tu-dominio.com/vantop-dashboard/auth/callback

# Ruta donde se guarda el token OAuth (fuera del directorio del proyecto)
OAUTH_TOKEN_PATH=/home/vantop/vantop-token.json
